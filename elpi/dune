(rocq.theory
 (name Sniper.elpi)
 (package rocq-sniper)
 (plugins rocq-elpi.elpi))

; The following stanza is required for Dune to handle generated files
; https://github.com/LPCIC/coq-elpi/blob/master/apps/derive/elpi/dune

(rule
 (target dummy.v)
 (deps
  (glob_files *.elpi))
 (action
  (with-stdout-to
   %{target}
   (echo "(* copy elpi files to _build *)"))))
